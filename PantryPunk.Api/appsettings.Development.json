{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PantryPunk": {
    "DevAuth": {
      "UserId": "auth0|devuser"
    },
    "Claude": {
      "Model": "claude-sonnet-4-6",
      "MaxTokensImage": 256
    }
  },
  "CosmosDb": {
    "AccountEndpoint": "https://localhost:8081",
    "DatabaseName": "PantryPunkDb"
  }
}
